# Secrets (do not commit real values)
PINECONE_API_KEY=pcsk_REPLACE_ME
ANTHROPIC_API_KEY=sk-ant_REPLACE_ME

# Pinecone
PINECONE_INDEX_NAME=dem-debates-transcripts
PINECONE_NAMESPACE=debates
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Optional: set this after index creation to avoid an extra control-plane call
# PINECONE_INDEX_HOST=https://YOUR-INDEX-HOST.pinecone.io

# Pinecone integrated embeddings (hosted by Pinecone)
PINECONE_EMBED_MODEL=multilingual-e5-large
PINECONE_EMBED_FIELD=chunk_text

# Anthropic
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Retrieval/prompt limits
TOP_K=8
MAX_CONTEXT_CHARS=12000
